{
  "name": "samiham_playwrightbdd_assessment",
  "version": "1.0.0",
  "description": "Playwright Cucumber TypeScript Assessment",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
  "register": "cucumber-js --config cucumber.js --tags @register",
  "login": "cucumber-js --config cucumber.js --tags @Login",
  "test": "cucumber-js",
  "smoke": "cucumber-js --tags @smoke",
  "regression": "cucumber-js --tags @regression",
  "parallel": "cucumber-js --parallel 2",
  "failed": "cucumber-js @rerun/rerun.txt",
  "report": "npx ts-node src/utils/report.mts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "allure-cucumberjs": "^3.10.2",
    "allure-js-commons": "^3.10.2",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "winston": "^3.19.0"
  }
}